# _headers — Civil Engineering Suite (Cloudflare Pages)
# Security headers for static files (images, CSS, sitemap, etc.)
# Headers for encrypted pages are set directly in functions/[[path]].js
# NOTE: These headers apply ONLY to static assets — NOT to Pages Function responses.
#       All security headers for function routes (/, /footing-pro/, etc.) are
#       applied programmatically inside functions/[[path]].js via SHARED_SECURITY_HEADERS.
#
# FIX LOG (2026-04-14):
# [F1] Added /public/* block: X-Robots-Tag + Cache-Control + Content-Disposition
#      → Prevents Google from indexing encrypted .enc files. Without this,
#        Googlebot could crawl /public/pc_suite.enc and waste crawl budget.
# [F2] Added Cache-Control to /* catch-all for static HTML sub-app pages
#      (beam-pro/index.html, column-pro/index.html, etc.)
#
# FIX LOG (2026-04-17): PAYMENT GATEWAY INTEGRATION
# [P1] Added /payment/* block:
#      → Overrides CSP to allow Paymob SDK (accept.paymob.com) for script, connect, frame
#      → Overrides Permissions-Policy to REMOVE payment=() which blocks the payment API
#      → Sets Cache-Control: no-store (payment pages must never be cached)
#      → Sets X-Robots-Tag: noindex (payment pages must not be indexed)
# [P2] NOTE: /api/payment/* routes are Cloudflare Pages Functions — they do NOT
#      inherit _headers rules. Security headers are applied inside each function file.
#      Cloudflare `_headers` rules: later (more-specific) path rules override
#      earlier (less-specific) rules for duplicate headers on the same response.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-DNS-Prefetch-Control: off
  X-Permitted-Cross-Domain-Policies: none
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), accelerometer=(), gyroscope=(), magnetometer=(), display-capture=(), screen-wake-lock=(), ambient-light-sensor=(), autoplay=(), clipboard-read=()
  # [F2] Default cache for static HTML pages (sub-apps: beam-pro etc.)
  Cache-Control: public, max-age=600, must-revalidate

# [F1] FIX: Block crawlers from indexing encrypted .enc source files
/public/*
  X-Robots-Tag: noindex, noarchive, nosnippet
  Cache-Control: no-store
  Content-Disposition: attachment

/404.html
  Cache-Control: public, max-age=60

/404.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/manifest.json
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *

/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/footing-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/beam-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/column-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/deflection-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/earthquake-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/mur-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/add-reft-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/section-property-pro/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/.well-known/*
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

# ════════════════════════════════════════════════════════════════
# [P1] PAYMENT PAGES — Override CSP and Permissions-Policy
#      Placed AFTER /* so it takes precedence for /payment/* routes.
#
#  CSP changes from global default:
#   script-src:  adds https://accept.paymob.com  (Paymob SDK: pay.js)
#   connect-src: adds https://accept.paymob.com  (Paymob API calls from SDK)
#   frame-src:   adds https://accept.paymob.com  (3DS authentication iframes)
#   img-src:     adds https://*.paymob.com        (Card brand logos in modal)
#   style-src:   adds 'unsafe-inline'             (Paymob SDK injects inline styles)
#   form-action: 'none'                           (all submission via JS fetch only)
#
#  Permissions-Policy changes:
#   payment=() REMOVED  → allows browser Payment Request API used by Paymob/Apple Pay
#
#  Cache-Control: no-store  → payment pages must NEVER be cached by any proxy
#  X-Robots-Tag: noindex    → checkout flow must not be indexed
# ════════════════════════════════════════════════════════════════

/payment/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://accept.paymob.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.paymob.com https://paymob.com; connect-src 'self' https://accept.paymob.com; frame-src https://accept.paymob.com; frame-ancestors 'none'; form-action 'none'; base-uri 'self'; upgrade-insecure-requests; report-uri /api/csp-report
  Permissions-Policy: camera=(), microphone=(), geolocation=(), accelerometer=(), gyroscope=(), magnetometer=(), display-capture=(), screen-wake-lock=(), autoplay=(), clipboard-read=()
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

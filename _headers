# ── Agent-discovery files — correct Content-Type per RFC / spec ──
# api-catalog:              application/linkset+json (RFC 9264 §4.2)
# agent-skills/index.json:  application/json
# mcp/server-card.json:     application/json
# oauth-protected-resource: application/json (RFC 9728)
# security.txt:             text/plain (RFC 9116)
/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/.well-known/mcp/server-card.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/.well-known/oauth-authorization-server
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/.well-known/oauth-protected-resource
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# ════════════════════════════════════════════════════════════════
# [P1] PAYMENT PAGES — Override CSP and Permissions-Policy
#      Placed AFTER /* so it takes precedence for /payment/* routes.
#
#  CSP changes from global default:
#   script-src:  adds https://accept.paymob.com  (Paymob SDK: pay.js)
#   connect-src: adds https://accept.paymob.com  (Paymob API calls from SDK)
#   frame-src:   adds https://accept.paymob.com  (3DS authentication iframes)
#   img-src:     adds https://*.paymob.com        (Card brand logos in modal)
#   style-src:   adds 'unsafe-inline'             (Paymob SDK injects inline styles)
#   form-action: 'none'                           (all submission via JS fetch only)
#
#  Permissions-Policy changes:
#   payment=() REMOVED  → allows browser Payment Request API used by Paymob/Apple Pay
#
#  Cache-Control: no-store  → payment pages must NEVER be cached by any proxy
#  X-Robots-Tag: noindex    → checkout flow must not be indexed
# ════════════════════════════════════════════════════════════════

/payment/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://accept.paymob.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.paymob.com https://paymob.com; connect-src 'self' https://accept.paymob.com; frame-src https://accept.paymob.com; frame-ancestors 'none'; form-action 'none'; base-uri 'self'; upgrade-insecure-requests; report-uri /api/csp-report
  Permissions-Policy: camera=(), microphone=(), geolocation=(), accelerometer=(), gyroscope=(), magnetometer=(), display-capture=(), screen-wake-lock=(), autoplay=(), clipboard-read=()
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
